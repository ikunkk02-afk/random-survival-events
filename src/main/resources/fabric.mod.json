{
	"schemaVersion": 1,
	"id": "random-survival-events",
	"version": "${version}",
	"name": "Random Survival Events",
	"description": "Adds configurable random survival events, rewards, disasters, and punishment events to Fabric survival worlds.",
	"authors": [
		"ikunkk02-afk"
	],
	"contact": {
		"homepage": "https://github.com/ikunkk02-afk/random-survival-events",
		"sources": "https://github.com/ikunkk02-afk/random-survival-events",
		"issues": "https://github.com/ikunkk02-afk/random-survival-events/issues"
	},
	"license": "MIT",
	"icon": "assets/random-survival-events/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.ikunkk02afk.randomsurvivalevents.RandomSurvivalEvents"
		],
		"client": [
			"com.ikunkk02afk.randomsurvivalevents.client.RandomSurvivalEventsClient"
		],
		"modmenu": [
			"com.ikunkk02afk.randomsurvivalevents.client.RandomSurvivalEventsModMenu"
		],
		"fabric-datagen": [
			"com.ikunkk02afk.randomsurvivalevents.client.RandomSurvivalEventsDataGenerator"
		],
		"cardinal-components-entity": [
			"com.ikunkk02afk.randomsurvivalevents.component.RandomSurvivalEventsComponents"
		]
	},
	"mixins": [
		"random-survival-events.mixins.json",
		{
			"config": "random-survival-events.client.mixins.json",
			"environment": "client"
		}
	],
	"custom": {
		"cardinal-components": [
			"random-survival-events:player_events"
		]
	},
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "1.21.1",
		"java": ">=21",
		"fabric-api": ">=0.116.11+1.21.1",
		"cardinal-components": ">=6.1.3",
		"cardinal-components-base": ">=6.1.3",
		"cardinal-components-entity": ">=6.1.3",
		"cloth-config": ">=15.0.140",
		"modmenu": ">=11.0.4"
	}
}
